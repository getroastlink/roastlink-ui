# Ignore everything by default
*

# But track these deployment folders and their contents
!core/
!core/*.bin
!core/*.json

!two/
!two/*.bin
!two/*.json

!twoplus/
!twoplus/*.bin
!twoplus/*.json

!corev2/
!corev2/*.bin
!corev2/*.json

!one/
!one/*.bin
!one/*.json

!coredev/
!coredev/*.bin
!coredev/*.json

!twoplusv2/
!twoplusv2/*.bin
!twoplusv2/*.json

# Also track .gitignore itself
!.gitignore

# Explicitly exclude secrets (already covered by * above, listed for clarity)
include/secrets.h
